{
  "name": "laser-helius",
  "version": "0.1.0",
  "private": true,
  "description": "Modular Solana whale copytrading backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test:direct-paths": "npm run build && node dist/scripts/test-direct-paths.js",
    "analyze:whale": "tsx tools/whale-analyzer.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@pump-fun/pump-sdk": "^1.32.0",
    "@pump-fun/pump-swap-sdk": "^1.14.1",
    "@raydium-io/raydium-sdk-v2": "^0.2.41-alpha",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@triton-one/yellowstone-grpc": "^5.0.8",
    "axios": "^1.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.5.0",
    "helius-laserstream": "^0.3.1",
    "telegraf": "^4.16.3",
    "ws": "^8.18.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
