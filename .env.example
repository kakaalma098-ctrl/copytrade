# Wallet
BOT_PRIVATE_KEY=

# Whale wallets pindah ke configuration.json -> field: whaleWallets
# Fallback legacy (opsional): WHALE_WALLETS=

# Helius
HELIUS_API_KEY=
# Feed mode (strict, no fallback): exactly one must be true.
HELIUS_LASER_GRPC=true
HELIUS_WSS=false
# Laserstream gRPC endpoint (required when HELIUS_LASER_GRPC=true).
# Note: gRPC mode now uses PREPROCESSED transactions — data delivered at
# shred-decode (~50–150ms earlier than confirmed) but without execution meta.
# Decoder works at instruction level: supports Pump.fun + PumpSwap fully,
# Jupiter v6 best-effort. Other protocols (Raydium / Meteora / LaunchLab)
# are skipped in this mode. Requires Helius Professional plan or higher.
HELIUS_LASERSTREAM_ENDPOINT=
# Ignored in PREPROCESSED mode (no commitment level applies). Kept here for
# back-compat — config still parses the value but it has no effect on grpc-pp.
HELIUS_LASERSTREAM_COMMITMENT=processed
# WSS endpoint (required when HELIUS_WSS=true).
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# WSS transactionSubscribe commitment: set `processed` for speed benchmark vs gRPC processed.
HELIUS_WSS_COMMITMENT=processed
# RPC URLs sekarang diatur di configuration.json -> field `rpcUrls` (array).
# Entry [0] = primary (dipakai untuk reads: blockhash, wallet state, ALT).
# Entry [1..] = extras (dipakai untuk N4 multi-sender race saat EXECUTION_MULTI_SENDER_RACE=true).
# Fallback legacy single-RPC: HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# processed = baca chain lebih cepat (Connection); confirmed/finalized lebih aman
HELIUS_RPC_COMMITMENT=processed
HELIUS_TIP_ENDPOINTS=http://sg-sender.helius-rpc.com/fast
# Opsional: batasi pubkey tip Sender (comma). Kosong = acak dari daftar bawaan di kode (tidak wajib isi)
HELIUS_TIP_ACCOUNTS=
# Opsional: batasi pubkey tip khusus mode jito (comma). Kosong = pakai default Jito hardcoded.
JITO_TIP_ACCOUNTS=

# Jupiter — mode:
# - metis_build: quote + /swap (tx dari Jupiter)
# - metis_instructions: quote + /swap-instructions (tx dirakit lokal, kontrol instruksi lebih penuh)
# - order_v2: /order (tx dari Jupiter)
# - auto: ikut URL base
JUPITER_SWAP_API_BASE=https://lite-api.jup.ag/swap/v1
JUPITER_INTEGRATION_MODE=auto
# Jupiter API keys pindah ke configuration.json -> field: jupiterApiKeys (array, auto-rotate)
# Fallback legacy (opsional): JUPITER_API_KEY=key1,key2,key3
# N1: restrict routing ke intermediate high-liquidity (hemat 20-50ms quote + tx
# lebih kecil -> landing rate naik). Set "false" untuk allow exotic routes.
JUPITER_RESTRICT_INTERMEDIATE_TOKENS=true
# Q1.2: cap route complexity. 0 = unlimited; 48-64 is safer for wider route coverage.
JUPITER_MAX_ACCOUNTS=64

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_MS=2000
TELEGRAM_QUEUE_MAX=200

# Trading
SLIPPAGE_BPS=50
FIXED_BUY_AMOUNT_SOL=0.35
# 0 = off; only follow whale BUY if amount >= this value (SOL)
MIN_WHALE_BUY_AMOUNT_SOL=0.7
REBUY_ENABLED=true
REBUY_MAX_COUNT=3
# true = SELL ikut proporsi whale (bertahap); false = SELL full 100% langsung
FOLLOW_WHALE_SELL=true
TRADING_PERSISTENT_WSOL=false
# Startup pre-wrap SOL -> WSOL (aman untuk mode persistent WSOL):
# - auto: ikut TRADING_PERSISTENT_WSOL (default)
# - true/false: paksa on/off
STARTUP_PREWRAP_WSOL=auto
# Target minimum saldo WSOL setelah startup (SOL). Kosong = ikut FIXED_BUY_AMOUNT_SOL.
STARTUP_PREWRAP_WSOL_TARGET_SOL=
# Sisakan SOL unwrapped untuk fee/tip/rent.
STARTUP_PREWRAP_SOL_RESERVE_SOL=0.05
DELAY_MS=0

# Performance (Phase 9)
QUOTE_CACHE_TTL_MS=2500
# Hot path: cache saldo SOL + posisi token per mint (SELL) — hindari RPC tiap sinyal (ms)
WALLET_STATE_CACHE_TTL_MS=280
# Log satu baris metrik latency ke console (pipeline / queue / risk / swapRpc)
LATENCY_LOG=false
# Startup: satu quote Jupiter kecil (SOL→USDC) untuk TLS + route cache
JUPITER_WARMUP=false
# N8: ALT addresses (comma-separated) to pre-resolve at startup. Populate with
# Jupiter's most-used routing ALTs you see in the logs after first run.
# Empty = skip. Each cold ALT saves ~20-40ms on first swap that needs it.
JUPITER_PREWARM_ALTS=
# Verbose: filter Laserstream + alasan decode gagal + signal:trade + broadcast gRPC (banyak log)
WHALE_DEBUG=false
# Dump whale tx dgn protocolHint=UNKNOWN ke logs/protocol_unknown.jsonl (buffer 30s, off hot path)
# Berguna untuk identifikasi DEX baru yang perlu ditambahkan ke detector
UNKNOWN_PROTOCOL_LOG=true

# Eksekusi (Fase 3): commitment confirm, prioritas fee Jupiter, kirim via Helius Sender
# processed = lebih cepat; confirmed / finalized = lebih aman
TX_CONFIRM_COMMITMENT=processed
# true = kirim raw tx lewat Sender (JSON-RPC), bukan Connection.sendRawTransaction
EXEC_USE_HELIUS_SENDER=true
EXEC_SENDER_MODE=auto
# Opsional: override URL Sender; kosong = pakai HELIUS_TIP_ENDPOINTS[0]
HELIUS_SENDER_URL=
# N5: pin Helius Sender ke regional subdomain untuk skip DNS auto-route
# (~10-30ms per send). Isi sesuai lokasi VPS: sgp / fra / ams / slc / ewr / tyo.
# Kosong = auto-route (default). Diabaikan kalau HELIUS_SENDER_URL di-set.
HELIUS_SENDER_REGION=sgp
JITO_SENDER_URL=https://mainnet.block-engine.jito.wtf/api/v1/transactions
# N4: race Helius + Jito + semua RPC (configuration.json -> rpcUrls) paralel
# tiap send. First fulfilled wins. Landing rate naik, outbound calls ~3-5x.
# Set ke "false" untuk legacy behavior (primary sender + RPC backup saja).
EXECUTION_MULTI_SENDER_RACE=true
# Level 2: background RTT healthcheck. Probe tiap send endpoint per N ms;
# endpoint dengan RTT > threshold auto-excluded dari race sampai recover.
# Hanya aktif saat EXECUTION_MULTI_SENDER_RACE=true.
RPC_HEALTH_CHECK_ENABLED=true
RPC_HEALTH_PROBE_INTERVAL_MS=10000
RPC_HEALTH_LATENCY_THRESHOLD_MS=150
RPC_HEALTH_PROBE_TIMEOUT_MS=3000
EXEC_TIP_ENABLED=true
# BUY no-fallback: kalau BUY gagal di layer mana pun (Jupiter v1 NO_ROUTES,
# direct-pump revert, dex-pref miss), abort langsung tanpa fallback. Missed
# entry < late entry di harga jauh lebih tinggi. SELL tetap pakai fallback
# penuh karena close position mandatory.
EXEC_BUY_NO_FALLBACK=false
# Tip per side (lamports). Helius Sender requires min 200000.
EXEC_TIP_LAMPORTS_BUY=500000
EXEC_TIP_LAMPORTS_SELL=800000
EXEC_FAST_ACK=false

# Runtime (Fase 4): konkurensi swap + dedup sinyal per signature tx whale
# Minimal 1 — handler menunggu slot bebas sebelum risk+swap berikutnya
MAX_CONCURRENT_SWAPS=2
# 0 = off; mis. 5000 = abaikan sinyal duplikat untuk tx whale yang sama dalam 5s
DEDUP_WHALE_TX_MS=0




